# ── Database ──
DATABASE_URL="postgresql://metis:metis_secret@localhost:5432/metis_dev?schema=public"

# ── Redis ──
REDIS_URL="redis://localhost:6379"

# ── Auth ──
AUTH_SECRET="change-me-in-production-use-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# ── API ──
API_PORT=4000
API_PREFIX="/v1"
CORS_ORIGIN="http://localhost:3000"

# ── Worker ──
WORKER_CONCURRENCY=5

# ── SMTP (Email Sending) ──
# For Gmail: use App Password (2FA required → https://myaccount.google.com/apppasswords)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM_NAME="Metis.AI"
# SMTP_FROM_EMAIL="your-email@gmail.com"

# ── Observability ──
OTEL_SERVICE_NAME="metis-api"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
LOG_LEVEL="debug"
